# Clé de chiffrement Fernet pour les données au repos (mapping anonymisation +
# tokens OAuth Claude). Génère-en une avec :
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ANON_DB_KEY=

# Port exposé sur l'hôte par docker-compose.yml (uniquement utilisé en
# déploiement Docker, sans effet en lancement direct via uvicorn).
ANON_PORT=8500

# --- Auth backend : "local" ou "ldap" ---
AUTH_BACKEND=local

# Mode local (AUTH_BACKEND=local) : plusieurs comptes possibles.
WEBAPP_USERS=admin:changeme,demo:demo1234
# Legacy (un seul compte), utilisé seulement si WEBAPP_USERS est absent :
# WEBAPP_USER=admin
# WEBAPP_PASSWORD=changeme

# Mode LDAP (AUTH_BACKEND=ldap) : décommente et configure.
# LDAP_SERVER=ldap://ldap.example.com:389        # ou ldaps://... pour SSL direct
# LDAP_USE_SSL=false                              # true si pas déjà ldaps://
# LDAP_BASE_DN=ou=people,dc=example,dc=com        # racine de recherche
#
# Mode A (recommandé, OpenLDAP et Active Directory) : recherche puis bind.
# LDAP_SEARCH_FILTER=(uid={username})             # AD: (sAMAccountName={username})
# LDAP_BIND_DN=cn=service-account,dc=example,dc=com   # vide = recherche anonyme
# LDAP_BIND_PASSWORD=
#
# Mode B (simple, si tu connais le format exact du DN, saute la recherche) :
# LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=com
#
# Optionnel : restreindre l'accès aux membres d'un groupe LDAP
# LDAP_REQUIRE_GROUP_DN=cn=claude-proxy-users,ou=groups,dc=example,dc=com

# Langue par défaut pour la détection NER (fr/en)
ANON_LANGUAGE=fr

# --- Licence ---
# Token signé fourni par le vendeur (alternative : le mettre dans
# data/license.lic, ce qui survit aux redéploiements via le volume ./data).
LICENSE_KEY=

# URL du serveur de licences (phone-home anti-piratage, optionnel mais
# recommandé). Sans réseau vers ce serveur, l'app tolère une grace period de
# LICENSE_GRACE_PERIOD_DAYS avant de bloquer la création de nouveaux comptes.
LICENSE_SERVER_URL=https://license.example.com
LICENSE_PHONE_HOME_INTERVAL=86400
LICENSE_GRACE_PERIOD_DAYS=14

# Optionnel : legacy, utilisé uniquement par proxy_cli.py (CLI hors webapp,
# facturation par clé API classique au lieu de l'abonnement Pro/Max OAuth)
# ANTHROPIC_API_KEY=
